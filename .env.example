# Copy this file to .env for local `cargo run` development. The systemd user
# service uses its own private state directory and does not read this repository
# copy of the file.

# Local SQLite state. Keep the database and encryption key private and back
# them up together; replacing the key makes imported tokens unreadable.
CODEX_LB_DATABASE_URL=sqlite://./.local/codex-lb.sqlite
CODEX_LB_ENCRYPTION_KEY_FILE=./.local/encryption.key

# Loopback server
HOST=127.0.0.1
PORT=2455

# Optional local API authentication. Leaving these unset is appropriate only
# while the daemon remains loopback-only. Set both before exposing HOST.
# CODEX_LB_ADMIN_TOKEN=replace-with-a-long-random-value
# CODEX_LB_PROXY_API_TOKEN=replace-with-a-different-long-random-value

# Upstream Codex/ChatGPT OAuth endpoints
CODEX_LB_UPSTREAM_BASE_URL=https://chatgpt.com/backend-api
CODEX_LB_AUTH_BASE_URL=https://auth.openai.com
CODEX_LB_OAUTH_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
CODEX_LB_OAUTH_SCOPE=openid profile email

# Lean background/runtime behavior
CODEX_LB_PROXY_REQUEST_BUDGET_SECONDS=600
CODEX_LB_TOKEN_REFRESH_INTERVAL_DAYS=8
CODEX_LB_USAGE_REFRESH_INTERVAL_SECONDS=120
