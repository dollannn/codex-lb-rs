# Copy this file to .env for local development.

# Postgres
CODEX_LB_DATABASE_URL=postgres://codex_lb:codex_lb@127.0.0.1:5432/codex_lb

# Server bind address
HOST=127.0.0.1
PORT=2455

# Security tokens. Set both in any shared/non-local environment.
CODEX_LB_ADMIN_TOKEN=change-me-admin-token
CODEX_LB_PROXY_API_TOKEN=change-me-proxy-token

# Upstream endpoints
CODEX_LB_UPSTREAM_BASE_URL=https://chatgpt.com/backend-api
CODEX_LB_AUTH_BASE_URL=https://auth.openai.com
CODEX_LB_OAUTH_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
CODEX_LB_OAUTH_SCOPE=openid profile email

# Runtime behavior
CODEX_LB_PROXY_REQUEST_BUDGET_SECONDS=600
CODEX_LB_TOKEN_REFRESH_INTERVAL_DAYS=8

# Token encryption key file. Keep this stable and backed up; changing it makes
# previously imported account tokens unreadable.
CODEX_LB_ENCRYPTION_KEY_FILE=./.local/encryption.key
